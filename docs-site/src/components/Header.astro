---
const { pathname } = Astro.url;
---

<header class="sticky top-0 z-50 bg-gradient-to-r from-[#C41E3A] via-[#DC3545] to-[#F57C00] shadow-xl backdrop-blur-sm bg-opacity-95">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20 lg:h-24">
      <!-- Logo -->
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 lg:w-12 lg:h-12 bg-white rounded-lg flex items-center justify-center">
          <span class="text-xl font-bold text-[#C41E3A]">📚</span>
        </div>
        <div class="flex flex-col">
          <span class="text-white font-bold text-lg lg:text-2xl">ComandaPro</span>
          <span class="text-white text-xs lg:text-sm">Documentation</span>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="hidden md:flex gap-8 items-center">
        <a href="/" class={`text-white hover:text-yellow-300 transition font-medium ${pathname === '/' ? 'border-b-2 border-white' : ''}`}>
          Docs
        </a>
        <a href="/blog/" class={`text-white hover:text-yellow-300 transition font-medium ${pathname.includes('/blog') ? 'border-b-2 border-white' : ''}`}>
          Blog
        </a>
        <a href="/guides/" class={`text-white hover:text-yellow-300 transition font-medium ${pathname.includes('/guides') ? 'border-b-2 border-white' : ''}`}>
          Guides
        </a>
        <a href="/faq/" class={`text-white hover:text-yellow-300 transition font-medium ${pathname.includes('/faq') ? 'border-b-2 border-white' : ''}`}>
          FAQ
        </a>
      </nav>

      <!-- CTA Button -->
      <a href="https://comanda-pro.com" target="_blank" class="bg-white text-[#C41E3A] px-6 py-2 rounded-xl font-bold hover:shadow-lg hover:scale-105 transition transform duration-300">
        Back to Site
      </a>
    </div>
  </div>
</header>
