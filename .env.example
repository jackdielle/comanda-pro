# Environment Variables for Production Deployment
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git — it contains secrets!

# Database Configuration (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xyz.us-east-1.neon.tech/gestore_db?sslmode=require
DATABASE_USERNAME=user
DATABASE_PASSWORD=password

# JWT Configuration
JWT_SECRET=YOUR_SECURE_256BIT_SECRET_KEY_MINIMUM_32_CHARS_LONG===
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# CORS Configuration (Frontend URL)
CORS_ALLOWED_ORIGINS=https://gestore-comande.vercel.app

# Spring Boot Profile
SPRING_PROFILES_ACTIVE=prod

# Server Port (optional, defaults to 8080 on Render)
PORT=8080
